---
import BaseLayout from "../layouts/BaseLayout.astro";
import TerminalShell from "../components/TerminalShell.astro";
import HeroCard from "../components/HeroCard.astro";
import ChatPreview from "../components/ChatPreview.astro";
import CommandList from "../components/CommandList.astro";
import CopyButton from "../components/CopyButton.astro";
import { site } from "../data/site";

const sep = "border-b border-[color:var(--line)] bg-[#0b0f15] px-3 py-1.5 text-[0.72rem] font-normal uppercase tracking-[0.08em] text-[color:var(--muted)]";
const row =
  "flex flex-col gap-[0.35rem] border-b border-dashed border-[color:var(--line)] px-2 py-2 pl-3 [&:last-child]:border-b-0 qrow-inner";
---

<BaseLayout>
  <TerminalShell>
    <section
      class:list={[
        "bento-shell grid w-full lg:flex-1 lg:h-full lg:min-h-0",
      ]}
      aria-label="IRC overview layout"
    >
      <div class="hero-shell min-h-0 min-w-0 max-lg:overflow-visible lg:[grid-area:hero]">
        <HeroCard />
      </div>

      <section class="quick-shell flex min-h-0 min-w-0 flex-col gap-3 overflow-visible lg:min-h-0 lg:[grid-area:quick]" aria-labelledby="quick-h">
        <div class="flex min-w-0 flex-wrap items-center justify-between gap-3">
          <h2 class="section section-tight mb-0 min-w-0 flex-1" id="quick-h">
            <span class="num">01</span>Get started fast
          </h2>
          <div
            class="inline-flex gap-0.5 rounded border border-[color:var(--line-2)] bg-[#0b0f15] p-0.5 focus-within:border-[color:var(--accent)]"
            role="radiogroup"
            aria-label="Operating system for WeeChat launch instructions"
          >
            <button
              type="button"
              class="os-toggle-btn is-active inline-flex h-7 w-8 cursor-pointer items-center justify-center rounded border-0 bg-transparent p-0 leading-none text-[color:var(--accent)] hover:bg-white/[0.04] hover:text-[color:var(--text)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-[color:var(--accent)] [&.is-active]:bg-[rgba(121,224,137,0.12)] [&.is-active]:text-[color:var(--accent)] [&.is-active]:[box-shadow:inset_0_0_0_1px_rgba(121,224,137,0.25)]"
              role="radio"
              aria-checked="true"
              data-os="mac"
              title="macOS"
              aria-label="macOS WeeChat commands"
            >
              <svg class="h-[1.1rem] w-[1.1rem] shrink-0" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path
                  fill="currentColor"
                  d="M18.71,19.5C17.88,20.74 17,21.95 15.66,21.97C14.32,22 13.89,21.18 12.37,21.18C10.84,21.18 10.37,21.95 9.1,22C7.79,22.05 6.8,20.68 5.96,19.47C4.25,17 2.94,12.45 4.7,9.39C5.57,7.87 7.13,6.91 8.82,6.88C10.1,6.86 11.32,7.75 12.11,7.75C12.89,7.75 14.37,6.68 15.92,6.84C16.57,6.87 18.39,7.1 19.56,8.82C19.47,8.88 17.39,10.1 17.41,12.63C17.44,15.65 20.06,16.66 20.09,16.67C20.06,16.74 19.67,18.11 18.71,19.5M13,3.5C13.73,2.67 14.94,2.04 15.94,2C16.07,3.17 15.6,4.35 14.9,5.19C14.21,6.04 13.07,6.7 11.95,6.61C11.8,5.46 12.36,4.26 13,3.5Z"
                />
              </svg>
            </button>
            <button
              type="button"
              class="os-toggle-btn inline-flex h-7 w-8 cursor-pointer items-center justify-center rounded border-0 bg-transparent p-0 leading-none text-[color:var(--muted)] hover:bg-white/[0.04] hover:text-[color:var(--text)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-[color:var(--accent)] [&.is-active]:bg-[rgba(121,224,137,0.12)] [&.is-active]:text-[color:var(--accent)] [&.is-active]:[box-shadow:inset_0_0_0_1px_rgba(121,224,137,0.25)]"
              role="radio"
              aria-checked="false"
              data-os="linux"
              title="Linux"
              aria-label="Linux WeeChat commands"
            >
              <svg class="h-[1.1rem] w-[1.1rem] shrink-0" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path
                  fill="currentColor"
                  d="M14.62,8.35C14.2,8.63 12.87,9.39 12.67,9.54C12.28,9.85 11.92,9.83 11.53,9.53C11.33,9.37 10,8.61 9.58,8.34C9.1,8.03 9.13,7.64 9.66,7.42C11.3,6.73 12.94,6.78 14.57,7.45C15.06,7.66 15.08,8.05 14.62,8.35M21.84,15.63C20.91,13.54 19.64,11.64 18,9.97C17.47,9.42 17.14,8.8 16.94,8.09C16.84,7.76 16.77,7.42 16.7,7.08C16.5,6.2 16.41,5.3 16,4.47C15.27,2.89 14,2.07 12.16,2C10.35,2.05 9,2.81 8.21,4.4C8,4.83 7.85,5.28 7.75,5.74C7.58,6.5 7.43,7.29 7.25,8.06C7.1,8.71 6.8,9.27 6.29,9.77C4.68,11.34 3.39,13.14 2.41,15.12C2.27,15.41 2.13,15.7 2.04,16C1.85,16.66 2.33,17.12 3.03,16.96C3.47,16.87 3.91,16.78 4.33,16.65C4.74,16.5 4.9,16.6 5,17C5.65,19.15 7.07,20.66 9.24,21.5C13.36,23.06 18.17,20.84 19.21,16.92C19.28,16.65 19.38,16.55 19.68,16.65C20.14,16.79 20.61,16.89 21.08,17C21.57,17.09 21.93,16.84 22,16.36C22.03,16.1 21.94,15.87 21.84,15.63Z"
                />
              </svg>
            </button>
            <button
              type="button"
              class="os-toggle-btn inline-flex h-7 w-8 cursor-pointer items-center justify-center rounded border-0 bg-transparent p-0 leading-none text-[color:var(--muted)] hover:bg-white/[0.04] hover:text-[color:var(--text)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-[color:var(--accent)] [&.is-active]:bg-[rgba(121,224,137,0.12)] [&.is-active]:text-[color:var(--accent)] [&.is-active]:[box-shadow:inset_0_0_0_1px_rgba(121,224,137,0.25)]"
              role="radio"
              aria-checked="false"
              data-os="windows"
              title="Windows"
              aria-label="Windows WeeChat commands"
            >
              <svg class="h-[1.1rem] w-[1.1rem] shrink-0" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path
                  fill="currentColor"
                  d="M3,12V6.75L9,5.43V11.91L3,12M20,3V11.75L10,11.9V5.21L20,3M3,13L9,13.09V19.9L3,18.75V13M20,13.25V22L10,20.09V13.1L20,13.25Z"
                />
              </svg>
            </button>
          </div>
        </div>
        <div
          class:list={[
            "quick-cmds scrollbar-pane grid gap-0 overflow-visible rounded border border-[color:var(--line)] bg-[#07090d]",
            "lg:min-h-0 lg:flex-1 lg:self-stretch",
          ]}
        >
          <div class={`${sep}`}>Launch WeeChat</div>
          <div class={`${row} qrow flex`} data-os-row="mac">
            <div class="flex w-full min-w-0 flex-col gap-2">
              <div class="flex min-w-0 items-start justify-between gap-3">
                <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">brew install weechat</code>
                <CopyButton value="brew install weechat" label="Copy Homebrew install command" />
              </div>
              <div class="flex min-w-0 items-start justify-between gap-3">
                <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">weechat</code>
                <CopyButton value="weechat" label="Copy WeeChat launch command" />
              </div>
            </div>
            <span class="text-[0.82rem] leading-snug text-[color:var(--muted)]">macOS: install, then run <code class="text-[0.8em] text-[color:var(--muted-2)]">weechat</code> in Terminal.</span>
          </div>
          <div class={`${row} qrow flex`} data-os-row="linux" hidden>
            <div class="flex w-full min-w-0 flex-col gap-2">
              <div class="flex min-w-0 items-start justify-between gap-3">
                <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">sudo apt install weechat</code>
                <CopyButton value="sudo apt install weechat" label="Copy apt install command" />
              </div>
              <div class="flex min-w-0 items-start justify-between gap-3">
                <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">weechat</code>
                <CopyButton value="weechat" label="Copy WeeChat launch command" />
              </div>
            </div>
            <span class="text-[0.82rem] leading-snug text-[color:var(--muted)]">Linux: install (Debian/Ubuntu), then run <code class="text-[0.8em] text-[color:var(--muted-2)]">weechat</code> in a terminal.</span>
          </div>
          <div class={`${row} qrow flex`} data-os-row="windows" hidden>
            <div class="flex w-full min-w-0 flex-col gap-2">
              <div class="flex min-w-0 items-start justify-between gap-3">
                <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">choco install weechat -y</code>
                <CopyButton value="choco install weechat -y" label="Copy Chocolatey install command" />
              </div>
              <div class="flex min-w-0 items-start justify-between gap-3">
                <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">weechat</code>
                <CopyButton value="weechat" label="Copy WeeChat launch command" />
              </div>
            </div>
            <span class="text-[0.82rem] leading-snug text-[color:var(--muted)]">Windows: install with Chocolatey, then run <code class="text-[0.8em] text-[color:var(--muted-2)]">weechat</code> (e.g. in WSL or on PATH).</span>
          </div>
          <div class={`${sep}`}>Connect in WeeChat</div>
          <div class={`${row} qrow flex`}>
            <div class="flex min-w-0 items-start justify-between gap-3">
              <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">/server add inovus {site.host}/{site.tlsPort} -ssl -nicks=yourname</code>
              <CopyButton value={`/server add inovus ${site.host}/${site.tlsPort} -ssl -nicks=yourname`} label="Copy WeeChat server add command" />
            </div>
            <span class="text-[0.82rem] leading-snug text-[color:var(--muted)]">TLS only — port {site.tlsPort}. Replace <code class="text-[0.8em] text-[color:var(--muted-2)]">yourname</code> with your nick</span>
          </div>
          <div class={`${row} qrow flex`}>
            <div class="flex min-w-0 items-start justify-between gap-3">
              <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">/connect inovus</code>
              <CopyButton value="/connect inovus" label="Copy WeeChat connect command" />
            </div>
            <span class="text-[0.82rem] leading-snug text-[color:var(--muted)]">Connect to the saved server</span>
          </div>
          <div class={`${row} qrow flex`}>
            <div class="flex min-w-0 items-start justify-between gap-3">
              <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">/join {site.defaultChannel}</code>
              <CopyButton value={`/join ${site.defaultChannel}`} label="Copy join command" />
            </div>
            <span class="text-[0.82rem] leading-snug text-[color:var(--muted)]">Join the lobby</span>
          </div>
          <div class={`${row} qrow flex`}>
            <div class="flex min-w-0 items-start justify-between gap-3">
              <code class="min-w-0 flex-1 break-words rounded border border-[rgba(121,224,137,0.2)] bg-[rgba(121,224,137,0.12)] px-1 py-px text-[0.82rem] text-[color:var(--accent)]">Hello, I am new here</code>
              <CopyButton value="Hello, I am new here" label="Copy first message" />
            </div>
            <span class="text-[0.82rem] leading-snug text-[color:var(--muted)]">Send your first message</span>
          </div>
        </div>
      </section>

      <div
        class:list={[
          "chat-shell chat-cell min-h-0 min-w-0 lg:[grid-area:chat]",
          "flex lg:min-h-0 lg:flex-col lg:overflow-hidden",
          "max-lg:!flex-none max-lg:!h-auto max-lg:!min-h-0 max-lg:!overflow-visible",
        ]}
      >
        <ChatPreview />
      </div>

      <div
        class:list={[
          "commands-shell min-h-0 min-w-0 lg:[grid-area:commands]",
          "flex max-lg:flex-none lg:flex-col lg:overflow-hidden",
        ]}
      >
        <CommandList />
      </div>

      <footer
        class:list={[
          "footer-shell flex flex-wrap items-center justify-between gap-2 lg:[grid-area:footer]",
          "rounded-md border border-[color:var(--line)] bg-[color:var(--inset)] px-4 py-3 text-[0.76rem] text-[color:var(--muted)] shrink-0",
        ]}
      >
        <span>
          <code class="rounded border border-[color:var(--line)] bg-[rgba(255,255,255,0.02)] px-1 py-px text-[0.92em] text-[color:var(--text)]">{site.host}</code>:
          <code class="rounded border border-[color:var(--line)] bg-[rgba(255,255,255,0.02)] px-1 py-px text-[0.92em] text-[color:var(--text)]">{site.tlsPort}</code>
        </span>
        <span class="flex flex-wrap gap-4">
          <a href={site.parentUrl} rel="noopener" class="text-[color:var(--accent)]">inovuslabs.org</a>
          <a href={`ircs://${site.host}:${site.tlsPort}`} rel="external" class="text-[color:var(--accent)]"
            >ircs://{site.host}</a>
        </span>
      </footer>
    </section>
  </TerminalShell>
</BaseLayout>

<style is:global>
  .bento-shell {
    display: grid;
    gap: 0.65rem;
    align-content: start;
    align-items: stretch;
    grid-template-columns: 1fr;
    grid-template-areas:
      "hero"
      "quick"
      "chat"
      "commands"
      "footer";
  }

  @media (width >= 1024px) {
    .bento-shell {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      grid-template-areas:
        "hero chat"
        "quick chat"
        "commands commands"
        "footer footer";
      grid-template-rows: auto minmax(0, 1fr) minmax(0, 1fr) auto;
    }
  }

  @media (width >= 1280px) {
    .bento-shell {
      grid-template-columns: minmax(0, 1.12fr) minmax(0, 1fr) minmax(0, 1fr);
      grid-template-areas:
        "hero hero chat"
        "quick commands chat"
        "footer footer footer";
      grid-template-rows: auto minmax(0, 1fr) auto;
    }
  }

  .quick-cmds .qrow[hidden] {
    display: none !important;
  }

  /* OS toggle active ring from script */
  .os-toggle-btn.is-active {
    color: var(--accent);
    background: var(--accent-soft);
    box-shadow: inset 0 0 0 1px rgba(121, 224, 137, 0.25);
  }
</style>

<script>
  const btns = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-os]"));
  const rows = Array.from(document.querySelectorAll<HTMLElement>("[data-os-row]"));

  const applyOs = (os: string) => {
    for (const row of rows) {
      row.hidden = row.getAttribute("data-os-row") !== os;
    }
    for (const btn of btns) {
      const active = btn.dataset.os === os;
      btn.classList.toggle("is-active", active);
      btn.setAttribute("aria-checked", String(active));
    }
  };

  for (const btn of btns) {
    btn.addEventListener("click", () => applyOs(btn.dataset.os ?? "mac"));
  }

  applyOs("mac");
</script>
