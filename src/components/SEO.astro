---
import { site, faq, howToSteps } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `IRC @ Inovus Labs (${site.host})`,
  description = `IRC server at ${site.host}:${site.tlsPort} (TLS) — a private, hands-on environment for Inovus Labs fellows to experience Internet Relay Chat and its legacy. Provisional service.`,
} = Astro.props;

const keywords = [
  "IRC",
  "Internet Relay Chat",
  "Inovus Labs",
  site.host,
  "IRC server",
  "IRC commands",
  "WeeChat",
  "irssi",
].join(", ");

const ircsUrl = `ircs://${site.host}:${site.tlsPort}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site.url}/#organization`,
      name: site.parentName,
      url: site.parentUrl,
      logo: `${site.url}/icons/favicon-32x32.png`,
      sameAs: [site.parentUrl],
    },
    {
      "@type": "WebSite",
      "@id": `${site.url}/#website`,
      url: site.url,
      name: "IRC @ Inovus Labs",
      description,
      publisher: { "@id": `${site.url}/#organization` },
      inLanguage: "en",
      image: site.ogImage,
      license: site.licenseUrl,
    },
    {
      "@type": "TechArticle",
      "@id": `${site.url}/#article`,
      headline: "How to connect to the Inovus Labs IRC server",
      description,
      author: { "@id": `${site.url}/#organization` },
      publisher: { "@id": `${site.url}/#organization` },
      mainEntityOfPage: site.url,
      inLanguage: "en",
      image: site.ogImage,
      datePublished: site.datePublished,
      dateModified: site.dateModified,
      keywords,
      articleSection: "IRC",
      about: ["IRC", "Internet Relay Chat", "WeeChat", "TLS", "real-time messaging"],
      proficiencyLevel: "Beginner",
      license: site.licenseUrl,
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: ["h1", ".lede", "#quick-h"],
      },
    },
    {
      "@type": "Service",
      "@id": `${site.url}/#service`,
      name: "Inovus Labs IRC",
      serviceType: "Internet Relay Chat (educational deployment)",
      description,
      provider: { "@id": `${site.url}/#organization` },
      audience: { "@type": "Audience", audienceType: "Inovus Labs fellows" },
      availableChannel: {
        "@type": "ServiceChannel",
        serviceUrl: ircsUrl,
        availableLanguage: ["en"],
      },
    },
    {
      "@type": "FAQPage",
      "@id": `${site.url}/#faq`,
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    },
    {
      "@type": "HowTo",
      "@id": `${site.url}/#howto-connect`,
      name: "Connect to the Inovus Labs IRC server with WeeChat",
      description: "Step-by-step instructions to install WeeChat, add the Inovus IRC server with TLS, connect, and join #lobby.",
      totalTime: "PT3M",
      inLanguage: "en",
      tool: [
        { "@type": "HowToTool", name: "WeeChat" },
        { "@type": "HowToTool", name: "Any IRC client with TLS support" },
      ],
      step: howToSteps.map((s, i) => ({
        "@type": "HowToStep",
        position: i + 1,
        name: s.name,
        text: s.text,
        ...(s.code ? { itemListElement: [{ "@type": "HowToDirection", text: s.code }] } : {}),
      })),
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${site.url}/#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "IRC @ Inovus Labs",
          item: site.url,
        },
      ],
    },
  ],
};
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content={site.parentName} />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<link rel="canonical" href={site.url} />

<link rel="alternate" hreflang="en" href={site.url} />
<link rel="alternate" hreflang="x-default" href={site.url} />
<link rel="alternate" type="text/markdown" href="/llms.txt" title="LLM-friendly summary" />
<link rel="alternate" type="text/markdown" href="/llms-full.txt" title="Full content for LLMs" />
<link rel="alternate" type="text/markdown" href="/faq.md" title="FAQ (markdown)" />

<meta name="dc.title" content={title} />
<meta name="dc.description" content={description} />
<meta name="dc.language" content="en" />
<meta name="dc.date" content={site.dateModified} />
<meta name="dc.creator" content={site.parentName} />
<meta name="dc.publisher" content={site.parentName} />
<meta name="dc.rights" content={site.licenseUrl} />
<meta name="dc.type" content="Service" />

<meta property="article:published_time" content={site.datePublished} />
<meta property="article:modified_time" content={site.dateModified} />

<meta name="theme-color" content="#0b0c0f" />
<meta name="msapplication-TileColor" content="#0b0c0f" />
<meta name="color-scheme" content="dark" />
<meta name="application-name" content="IRC @ Inovus Labs" />
<meta name="apple-mobile-web-app-title" content="IRC @ Inovus Labs" />
<meta name="format-detection" content="telephone=no" />

<link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/icons/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="IRC @ Inovus Labs" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={site.url} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={site.ogImage} />
<meta property="og:image:alt" content={`IRC @ Inovus Labs — Internet Relay Chat (${site.host})`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={site.ogImage} />
<meta name="twitter:image:alt" content={`IRC @ Inovus Labs — Internet Relay Chat (${site.host})`} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline></script>
