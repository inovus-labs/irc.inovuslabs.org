---
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `IRC @ Inovus Labs (${site.host})`,
  description = `IRC server at ${site.host}:${site.tlsPort} (TLS) — learn and explore classic Internet Relay Chat at your own pace.`,
} = Astro.props;

const keywords = [
  "IRC",
  "Internet Relay Chat",
  "Inovus Labs",
  site.host,
  "IRC server",
  "IRC commands",
  "WeeChat",
  "irssi",
].join(", ");

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site.url}/#organization`,
      name: site.parentName,
      url: site.parentUrl,
      sameAs: [site.parentUrl],
    },
    {
      "@type": "WebSite",
      "@id": `${site.url}/#website`,
      url: site.url,
      name: "IRC @ Inovus Labs",
      description,
      publisher: { "@id": `${site.url}/#organization` },
      inLanguage: "en",
      image: site.ogImage,
    },
    {
      "@type": "TechArticle",
      headline: "IRC landing",
      description,
      author: { "@id": `${site.url}/#organization` },
      publisher: { "@id": `${site.url}/#organization` },
      mainEntityOfPage: site.url,
      inLanguage: "en",
      about: ["IRC", "Internet Relay Chat", "classic real-time messaging"],
    },
  ],
};
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content={site.parentName} />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<link rel="canonical" href={site.url} />

<meta name="theme-color" content="#0b0c0f" />
<meta name="msapplication-TileColor" content="#0b0c0f" />
<meta name="color-scheme" content="dark" />
<meta name="application-name" content="IRC @ Inovus Labs" />
<meta name="apple-mobile-web-app-title" content="IRC @ Inovus Labs" />
<meta name="format-detection" content="telephone=no" />

<link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/icons/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="IRC @ Inovus Labs" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={site.url} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={site.ogImage} />
<meta property="og:image:alt" content={`IRC @ Inovus Labs — Internet Relay Chat (${site.host})`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={site.ogImage} />
<meta name="twitter:image:alt" content={`IRC @ Inovus Labs — Internet Relay Chat (${site.host})`} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline></script>
