---
import { commands } from "../data/site";
import CopyButton from "./CopyButton.astro";
---
<section
  class:list={[
    "commands-card card flex w-full min-h-0 flex-col overflow-visible p-[clamp(0.85rem,2vw,1.15rem)]",
    "lg:h-full lg:min-h-0 lg:flex-1 lg:overflow-hidden",
  ]}
  id="commands"
  aria-labelledby="cmd-h"
>
  <h2 class="section mb-4 shrink-0" id="cmd-h">
    <span class="num">03</span>Command cheat sheet
  </h2>
  <dl
    class:list={[
      "scrollbar-pane cmds grid grid-cols-1 gap-0 rounded border border-[color:var(--line)] bg-[#07090d] lg:flex-1 lg:min-h-0",
    ]}
  >
    {
      commands.map((c) => (
        <div class="flex flex-col gap-[0.35rem] border-b border-dashed border-[color:var(--line)] px-[0.62rem] py-[0.42rem] pl-[0.75rem] transition-colors last:border-b-0 hover:bg-[rgba(121,224,137,0.03)] max-[480px]:px-[0.55rem] max-[480px]:pl-[0.65rem] max-[480px]:py-[0.42rem]">
          <div class="flex min-w-0 items-start justify-between gap-[0.65rem]">
            <code class="min-w-0 flex-1 break-words font-mono text-[0.92em] text-[color:var(--accent)]">{c.cmd}</code>
            <CopyButton value={c.cmd} label="Copy command" />
          </div>
          <span class="break-words pl-[0.05rem] text-[0.82rem] leading-snug text-[color:var(--muted)]">{c.desc}</span>
        </div>
      ))
    }
  </dl>
</section>
