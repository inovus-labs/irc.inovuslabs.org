---
import { site } from "../data/site";
import CopyButton from "./CopyButton.astro";
const fullAddress = `${site.host}:${site.tlsPort}`;
---
<section class="card hero" aria-labelledby="page-title">
  <p class="eyebrow">{site.network} · irc</p>

  <h1 id="page-title">Internet Relay Chat (IRC) by Inovus Labs, ready to try hands-on.</h1>

  <p class="lede">
    {site.host} is deployed for experiments, tryouts, and practical Internet Relay Chat (IRC) testing.
    Connect, explore commands, and see how it behaves in real time.
  </p>

  <div class="target" aria-label="server address">
    <span class="dotpulse" aria-hidden="true"></span>
    <span class="addr"><code>{site.host}</code>:<code>{site.tlsPort}</code></span>
    <CopyButton value={fullAddress} label="Copy server address" />
  </div>

</section>

<style>
  .hero { position: relative; overflow: hidden; }
  .hero::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 6px;
    pointer-events: none;
    background: radial-gradient(420px 200px at 0% 0%, rgba(121, 224, 137, 0.08), transparent 70%);
  }

  .eyebrow {
    margin: 0 0 0.55rem;
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 0.55rem;
    color: var(--text-strong);
    font-size: clamp(1.1rem, 1.1vw + 0.7rem, 1.95rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    max-width: none;
  }

  .lede {
    margin: 0;
    color: var(--muted);
    max-width: none;
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .target {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.7rem;
    padding: 0.38rem 0.5rem 0.38rem 0.65rem;
    border: 1px solid var(--line-2);
    background: #0a0c10;
    border-radius: 4px;
    font-size: 0.86rem;
    color: var(--text-strong);
  }
  .target .addr code {
    color: var(--text-strong);
    font-family: inherit;
  }
  .dotpulse {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-glow);
    animation: pulse 1.8s ease-out infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 var(--accent-glow); }
    70%  { box-shadow: 0 0 0 8px rgba(121, 224, 137, 0); }
    100% { box-shadow: 0 0 0 0 rgba(121, 224, 137, 0); }
  }

</style>
