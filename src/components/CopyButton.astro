---
interface Props {
  value: string;
  label?: string;
  size?: "sm" | "md";
}
const { value, label = "Copy", size = "sm" } = Astro.props;
---
<button
  class:list={["copy-btn", size]}
  type="button"
  data-copy={value}
  aria-label={`${label}: ${value}`}
  title={label}
>
  <svg class="i i-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="9" y="9" width="13" height="13" rx="2" />
    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
  </svg>
  <svg class="i i-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="20 6 9 17 4 12" />
  </svg>
  <span class="sr">Copy</span>
</button>

<style>
  .copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.3rem;
    border: 1px solid var(--line-2);
    background: rgba(255, 255, 255, 0.015);
    color: var(--muted);
    border-radius: 4px;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
    font: inherit;
    line-height: 0;
    flex: 0 0 auto;
  }
  .copy-btn.sm { padding: 0.25rem; }
  .copy-btn.md { padding: 0.4rem 0.55rem; }

  .copy-btn:hover, .copy-btn:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
    outline: none;
  }
  .copy-btn:active { transform: scale(0.96); }

  .i { width: 14px; height: 14px; display: block; transition: opacity 0.15s ease, transform 0.2s ease; }
  .copy-btn.md .i { width: 16px; height: 16px; }

  .i-check { display: none; color: var(--accent); }

  .copy-btn.copied { color: var(--accent); border-color: var(--accent); background: var(--accent-soft); }
  .copy-btn.copied .i-copy { display: none; }
  .copy-btn.copied .i-check { display: block; animation: pop 0.25s ease; }

  @keyframes pop {
    from { transform: scale(0.6); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .sr {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
</style>

<script>
  const onClick = async (e: Event) => {
    const target = e.target as HTMLElement;
    const btn = target.closest<HTMLButtonElement>(".copy-btn");
    if (!btn) return;
    const value = btn.getAttribute("data-copy");
    if (!value) return;
    try {
      await navigator.clipboard.writeText(value);
    } catch {
      const ta = document.createElement("textarea");
      ta.value = value;
      ta.setAttribute("readonly", "");
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand("copy"); } catch {}
      ta.remove();
    }
    btn.classList.add("copied");
    btn.setAttribute("aria-label", "Copied!");
    window.setTimeout(() => {
      btn.classList.remove("copied");
      const v = btn.getAttribute("data-copy") ?? "";
      btn.setAttribute("aria-label", `Copy: ${v}`);
    }, 1500);
  };

  document.addEventListener("click", onClick);
</script>
