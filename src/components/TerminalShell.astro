---
import { site, youNick, members } from "../data/site";

const onlineCount = members.length;
---
<main id="main">
  <div class="titlebar" aria-hidden="true">
    <span class="dots">
      <span class="dot r"></span>
      <span class="dot y"></span>
      <span class="dot g"></span>
    </span>
    <span class="who"><b>{youNick}</b>@{site.network} — {site.host}</span>
    <span class="status" title={`${onlineCount} users online`}>
      <span class="ping" aria-hidden="true"></span>
      <span class="status-text">{onlineCount} online</span>
    </span>
  </div>

  <div class="promptbar">
    <span class="prompt-text">welcome to the {site.network} irc network</span>
    <span class="caret" aria-hidden="true"></span>
  </div>

  <div class="content">
    <slot />
  </div>
</main>

<style>
  main {
    width: 100%;
    max-width: 1480px;
    margin: 0 auto;
    height: calc(100dvh - (2 * clamp(0.5rem, 2.5vw, 2.25rem)));
    border: 1px solid var(--line-2);
    background: linear-gradient(180deg, var(--panel) 0%, var(--panel-2) 100%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.02) inset,
      0 30px 80px -30px rgba(0, 0, 0, 0.7),
      0 0 60px -20px rgba(121, 224, 137, 0.08);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  @media (prefers-reduced-motion: no-preference) {
    main { animation: rise 0.5s ease-out both; }
    @keyframes rise {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: none; }
    }
  }

  .titlebar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.6rem;
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, #14181f 0%, #0e1218 100%);
  }
  .dots { display: inline-flex; gap: 0.35rem; }
  .dot {
    width: 11px; height: 11px; border-radius: 50%;
    background: #2a2f29;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .dot.r { background: #f4736a; }
  .dot.y { background: #f4cf7d; }
  .dot.g { background: #79e089; }

  .who {
    font-size: 0.78rem;
    color: var(--muted);
    margin-left: 0.4rem;
  }
  .who b { color: var(--text); font-weight: 500; }

  .status {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    color: var(--muted);
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(121,224,137,0.04);
  }
  .ping {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-glow);
    animation: ping 1.8s ease-out infinite;
  }
  @keyframes ping {
    0%   { box-shadow: 0 0 0 0 var(--accent-glow); }
    70%  { box-shadow: 0 0 0 7px rgba(121, 224, 137, 0); }
    100% { box-shadow: 0 0 0 0 rgba(121, 224, 137, 0); }
  }
  .status-text { color: var(--text); }

  .promptbar {
    padding: 0.5rem 0.95rem;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.82rem;
    background: var(--inset);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .promptbar::before {
    content: "irc@inovuslabs:~$";
    color: var(--accent);
  }
  .caret {
    display: inline-block;
    width: 8px; height: 1em;
    background: var(--accent);
    vertical-align: -2px;
    animation: blink 1.05s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .content {
    padding: clamp(0.8rem, 1.6vw, 1.15rem);
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .content > :global(*) {
    flex: 1;
    min-height: 0;
    width: 100%;
  }
</style>
