---
import { site, youNick, members } from "../data/site";

const onlineCount = members.length;
---
<main
  id="main"
  class:list={[
    "terminal-shell",
    "mx-auto flex w-full max-w-[1480px] flex-col",
    "max-lg:h-auto max-lg:min-h-0 max-lg:w-full max-lg:p-0",
    "lg:mx-auto lg:h-[calc(100dvh-2_*_clamp(0.5rem,2.5vw,2.25rem))] lg:min-h-0 lg:overflow-hidden",
  ]}
>
  <div aria-hidden="true" class="terminal-head">
    <span class="terminal-traffic">
      <span class="traffic traffic-close" aria-hidden="true"></span>
      <span class="traffic traffic-min" aria-hidden="true"></span>
      <span class="traffic traffic-max" aria-hidden="true"></span>
    </span>
    <span class="terminal-who">
      <strong>{youNick}</strong>@{site.network}
      <span class="terminal-who-sep" aria-hidden="true">—</span>
      <span class="terminal-who-host">{site.host}</span>
    </span>
    <span class="terminal-badge" title={`${onlineCount} users online`}>
      <span class="status-ping" aria-hidden="true"></span>
      <span class="terminal-badge-text">{onlineCount} online</span>
    </span>
  </div>

  <div class="terminal-prompt">
    <span class="terminal-prompt-bar">irc@inovuslabs:~$</span>
    <span>welcome to the {site.network} irc network</span>
    <span class="caret-inline" aria-hidden="true"></span>
  </div>

  <div class="terminal-content flex min-h-0 flex-1 flex-col p-[clamp(0.8rem,1.6vw,1.15rem)] max-lg:flex-none lg:min-h-0 lg:overflow-hidden">
    <slot />
  </div>
</main>

<style>
  /* Outer frame: same panel on all breakpoints; mobile was missing border/gradient and looked broken */
  .terminal-shell {
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid var(--line-2);
    background: linear-gradient(to bottom, var(--panel), var(--panel-2));
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.03),
      0 18px 44px -22px rgba(0, 0, 0, 0.65),
      0 0 40px -18px rgba(121, 224, 137, 0.06);
  }

  @media (width >= 1024px) {
    .terminal-shell {
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.03),
        0 30px 80px -30px rgba(0, 0, 0, 0.7),
        0 0 60px -20px rgba(121, 224, 137, 0.08);
    }
  }

  /* Title bar: grid keeps traffic / identity / badge aligned; host line wraps cleanly on narrow viewports */
  .terminal-head {
    flex-shrink: 0;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(0.4rem, 2.2vw, 0.75rem);
    padding: clamp(0.45rem, 2.2vw, 0.65rem) clamp(0.6rem, 3vw, 0.9rem);
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, #14181f 0%, #0e1218 100%);
  }
  @media (max-width: 480px) {
    .terminal-head {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      row-gap: 0.4rem;
    }

    .terminal-traffic {
      grid-column: 1;
      grid-row: 1;
    }

    .terminal-badge {
      grid-column: 2;
      grid-row: 1;
      justify-self: end;
    }

    .terminal-who {
      grid-column: 1 / -1;
      grid-row: 2;
    }
  }

  .terminal-traffic {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .traffic {
    display: block;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
  }
  .traffic-close {
    background: #f4736a;
  }
  .traffic-min {
    background: #f4cf7d;
  }
  .traffic-max {
    background: #79e089;
  }

  .terminal-who {
    min-width: 0;
    font-size: clamp(0.7rem, 2.8vw, 0.78rem);
    line-height: 1.4;
    color: var(--muted);
    word-break: break-word;
  }
  .terminal-who strong {
    font-weight: 600;
    color: var(--text-strong);
  }
  .terminal-who-sep {
    margin: 0 0.2em;
    white-space: nowrap;
  }
  .terminal-who-host {
    display: inline;
  }

  .terminal-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    flex-shrink: 0;
    padding: 0.28rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(121, 224, 137, 0.06);
    color: var(--muted);
    font-size: clamp(0.66rem, 2.4vw, 0.72rem);
    line-height: 1.2;
    white-space: nowrap;
  }
  .terminal-badge-text {
    color: var(--text);
  }

  .status-ping {
    display: block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-glow);
  }

  .terminal-prompt {
    border-bottom: 1px solid var(--line);
    background: var(--inset);
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    word-break: break-word;
    padding: clamp(0.45rem, 2vw, 0.55rem) clamp(0.75rem, 3vw, 1rem);
    font-size: clamp(0.76rem, 2.6vw, 0.82rem);
  }

  .terminal-prompt-bar {
    color: var(--accent);
    font-weight: 500;
    flex-shrink: 0;
  }

  .caret-inline {
    display: inline-block;
    width: 8px;
    height: 1em;
    flex-shrink: 0;
    background: var(--accent);
    vertical-align: -2px;
    animation: caretBlink 1.05s steps(1, end) infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .caret-inline {
      animation: none;
    }
  }

  @supports (prefers-reduced-motion: no-preference) {
    main.terminal-shell {
      animation: rise 0.5s ease-out both;
    }
    main.terminal-shell .status-ping {
      animation: pingGlow 1.8s ease-out infinite;
    }
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes pingGlow {
    0% {
      box-shadow: 0 0 0 0 var(--accent-glow);
    }
    70% {
      box-shadow: 0 0 0 7px rgba(121, 224, 137, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(121, 224, 137, 0);
    }
  }
  @keyframes caretBlink {
    50% {
      opacity: 0;
    }
  }
</style>
